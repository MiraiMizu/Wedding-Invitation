{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wedding-invitation",
  "compatibility_date": "2025-09-27",
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "INVITATIONS",
      "id": "PLACEHOLDER_REPLACE_WITH_KV_ID"
    }
  ],
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
